# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Build artifacts
build/
dist/

# Spyder
.spyproject/
.spyderproject

# Results (keep folder, ignore generated artifacts)
results/data/**
results/figures/**
!results/data/.gitkeep
!results/figures/.gitkeep
*.npz
*.npy

# OMC / agent session state
.omc/

# Agent harness: local-only overrides and the verification-gate markers.
# Shared harness (.claude/settings.json, agents, commands) IS committed.
.claude/settings.local.json
.claude/.verify-dirty
.claude/.knowledge-dirty

# Source PDFs: large / often copyrighted. The committed index is
# references/pdfs/manifest.yaml (cite + sha256 + url); the PDFs stay local.
references/pdfs/*.pdf

# Environments
.venv/
venv/
env/

# LaTeX build artifacts (keep .tex/.bib, ignore generated files)
*.aux
*.bbl
*.blg
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
docs/paper/*.pdf

# Secrets & credentials — never commit to a public template.
# (These block accidental FILE commits; they do NOT scrub the commit-author
#  email in git metadata — use a GitHub noreply email for that.)
.env
.env.*
!.env.example
*.pem
*.key
id_rsa
id_ed25519
*.p12
*.pfx
.pypirc
.netrc
secrets.*
credentials.*
*_secret*
*.credentials.json

# OS
.DS_Store
Thumbs.db
