<?xml version="1.0"?>
<!--
  Planar double pendulum (2-DOF), revolute joints about the Y axis.
  A minimal, fully-specified URDF (mass + inertia on every link) so Pinocchio can
  build a valid dynamic model. Both links: length 1 m, mass 1 kg, point-like inertia
  approximated as a thin rod about the joint.
-->
<robot name="double_pendulum">

  <!-- Fixed base -->
  <link name="base_link">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
  </link>

  <!-- Link 1 -->
  <link name="link1">
    <inertial>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0833" ixy="0" ixz="0" iyy="0.0833" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="1.0"/></geometry>
    </visual>
  </link>

  <!-- Link 2 -->
  <link name="link2">
    <inertial>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0833" ixy="0" ixz="0" iyy="0.0833" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="1.0"/></geometry>
    </visual>
  </link>

  <!-- Joint 1: base -> link1 -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="100.0" velocity="20.0"/>
  </joint>

  <!-- Joint 2: link1 -> link2 (at the tip of link1) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 -1.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="100.0" velocity="20.0"/>
  </joint>

</robot>
